import { fetch } from 'wix-fetch'; //
import wixData from 'wix-data'; //
import { getSecret } from 'wix-secrets-backend'; // ייבוא ספריית הסודות של Wix

/**
 * פונקציה לקבלת תשובה מה-AI עם מנגנון ריטריי והקשר טכני מה-CMS.
 * מושכת את ה-API Key בצורה מאובטחת מה-Secrets Manager.
 */
export async function getTechnicalAdvice(userQuery) {
    // משיכת המפתח שהגדרת בשם GEMINI_API_KEY
    const apiKey = await getSecret("GEMINI_API_KEY"); 
    
    // שליפת הקשר מה-CMS (מוצרים ומפרטים)
    let productContext = "";
    try {
        const productsResult = await wixData.query("Products")
            .limit(50) // הגדלנו ל-50 לקבלת הקשר רחב יותר
            .find();
        productContext = productsResult.items.map(p => `${p.name}: ${p.description}`).join('\n'); //
    } catch (e) {
        console.error("שגיאה במשיכת נתונים מה-CMS", e); //
    }

    const systemPrompt = `אתה יועץ טכני מקצועי לחומרי בניין בחנות "סבן". 
    מומחה באיטום, הדבקה, גבס ובנייה מתקדמת.
    הקשר של המוצרים והמלאי הזמין אצלנו:
    ${productContext}
    
    הנחיות:
    1. ענה בעברית בלבד.
    2. היה מקצועי, תמציתי ומדויק.
    3. אם חומר ספציפי מהרשימה מתאים לשאלה, המלץ עליו.
    4. אם אינך בטוח, הצע ליצור קשר עם מומחה אנושי בחנות.
    5. שמור על טון עוזר ואמין.`;

    // שימוש בגרסת המודל המעודכנת
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`;

    const payload = {
        contents: [{ parts: [{ text: userQuery }] }],
        systemInstruction: { parts: [{ text: systemPrompt }] } //
    };

    // לוגיקת Exponential Backoff
    let retries = 0;
    const maxRetries = 5;

    while (retries <= maxRetries) { //
        try {
            const response = await fetch(url, {
                method: 'POST',
                body: JSON.stringify(payload),
                headers: { 'Content-Type': 'application/json' }
            }); //

            if (response.ok) { //
                const result = await response.json();
                return result.candidates?.[0]?.content?.parts?.[0]?.text || "מצטער, השרת לא החזיר תשובה."; //
            }

            if (response.status !== 429 && response.status < 500) {
                throw new Error(`API Error: ${response.status}`); //
            }
        } catch (err) {
            if (retries === maxRetries) throw err; //
        }

        const waitTime = Math.pow(2, retries) * 1000; //
        await new Promise(resolve => setTimeout(resolve, waitTime)); //
        retries++;
    }

    return "מצטער, חלה שגיאה מתמשכת בחיבור ליועץ. נסה שוב מאוחר יותר."; //
}
