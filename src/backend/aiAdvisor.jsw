import { fetch } from 'wix-fetch';
import wixData from 'wix-data';

/**
 * פונקציה לקבלת תשובה מה-AI עם מנגנון ריטריי (Backoff)
 */
export async function getTechnicalAdvice(userQuery) {
    const apiKey = ""; // המפתח יוזרק אוטומטית בסביבת ההרצה
    
    // שליפת הקשר מה-CMS
    let productContext = "";
    try {
        const productsResult = await wixData.query("Products").limit(20).find();
        productContext = productsResult.items.map(p => `${p.name}: ${p.description}`).join('\n');
    } catch (e) {
        console.error("Data fetch error", e);
    }

    const systemPrompt = `You are a professional technical consultant for building materials. 
    Expert in: Waterproofing, Adhesives, Gypsum, and Construction.
    Current Inventory context:
    ${productContext}
    Answer in Hebrew, be professional and concise. If unsure, refer to a human expert.`;

    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

    const payload = {
        contents: [{ parts: [{ text: userQuery }] }],
        systemInstruction: { parts: [{ text: systemPrompt }] }
    };

    // לוגיקת Exponential Backoff (1s, 2s, 4s, 8s, 16s)
    let retries = 0;
    const maxRetries = 5;

    while (retries <= maxRetries) {
        try {
            const response = await fetch(url, {
                method: 'POST',
                body: JSON.stringify(payload),
                headers: { 'Content-Type': 'application/json' }
            });

            if (response.ok) {
                const result = await response.json();
                return result.candidates?.[0]?.content?.parts?.[0]?.text || "לא התקבלה תשובה מהיועץ.";
            }

            if (response.status !== 429 && response.status < 500) {
                throw new Error(`API Error: ${response.status}`);
            }
        } catch (err) {
            if (retries === maxRetries) throw err;
        }

        const waitTime = Math.pow(2, retries) * 1000;
        await new Promise(resolve => setTimeout(resolve, waitTime));
        retries++;
    }

    return "מצטער, חלה שגיאה מתמשכת בחיבור. נסה שוב מאוחר יותר.";
}
