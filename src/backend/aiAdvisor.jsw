import { fetch } from 'wix-fetch';
import wixData from 'wix-data';
import { getSecret } from 'wix-secrets-backend';

/**
 * פונקציה לניקוי תגיות HTML מטקסט
 */
function stripHTML(text) {
    if (!text) return "";
    return text.replace(/<[^>]*>?/gm, '');
}

/**
 * פונקציה לשמירת שיחה ב-Collection "Import 1"
 */
async function saveConversation(userQuery, aiResponse, category = "General") {
    const cleanQuery = stripHTML(userQuery);
    const cleanResponse = stripHTML(aiResponse);

    const itemToSave = {
        "question": cleanQuery,
        "answer": cleanResponse,
        "category": category,
        "timestamp": new Date()
    };

    try {
        await wixData.insert("Import 1", itemToSave);
        console.log("Conversation saved to Import 1");
    } catch (err) {
        console.error("Failed to save to Collection:", err);
    }
}

export async function getTechnicalAdvice(userQuery) {
    const apiKey = await getSecret("GEMINI_API_KEY");
    
    // שליפת הקשר מוצרים (השארתי את הלוגיקה הקיימת שלך)
    let productContext = "";
    try {
        const productsResult = await wixData.query("Products").limit(50).find();
        productContext = productsResult.items.map(p => `${p.name}: ${p.description}`).join('\n');
    } catch (e) { console.error("CMS Error", e); }

    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`;
    
    const payload = {
        contents: [{ parts: [{ text: userQuery }] }],
        systemInstruction: { parts: [{ text: `אתה יועץ טכני לסבן. מלאי: ${productContext}` }] }
    };

    try {
        const response = await fetch(url, {
            method: 'POST',
            body: JSON.stringify(payload),
            headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
            const result = await response.json();
            const aiAnswer = result.candidates?.[0]?.content?.parts?.[0]?.text || "";
            
            // כאן קורה הקסם: ניקוי ושמירה אוטומטית בכל שאלה
            await saveConversation(userQuery, aiAnswer, "Technical Support");
            
            return aiAnswer;
        }
    } catch (err) {
        console.error("API Error", err);
    }
    return "שגיאה בחיבור ליועץ.";
}
