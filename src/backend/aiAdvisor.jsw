import { fetch } from 'wix-fetch';
import wixData from 'wix-data';

/**
 * פונקציה לקבלת תשובה מה-AI עם הקשר מה-CMS
 */
export async function getTechnicalAdvice(userQuery) {
    const apiKey = ""; // המפתח מוזרק אוטומטית בסביבת ההרצה
    
    // שליפת נתונים מה-CMS כדי שה-AI יהיה מומחה לחומרים שלך
    let productContext = "";
    try {
        const productsResult = await wixData.query("Products").limit(50).find();
        productContext = productsResult.items.map(p => `${p.name}: ${p.description}`).join('\n');
    } catch (e) {
        console.error("Data fetch error", e);
    }

    const systemPrompt = `You are a professional technical consultant for building materials at 'Saban'. 
    Expert in: Waterproofing, Adhesives, Gypsum, and Construction.
    Your inventory:
    ${productContext}
    Instructions:
    - Answer in Hebrew.
    - Be professional, accurate, and helpful.
    - If a specific product from the context fits the user's needs, recommend it.
    - If you don't know, suggest contacting Saban's technical support directly.`;

    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

    const payload = {
        contents: [{ parts: [{ text: userQuery }] }],
        systemInstruction: { parts: [{ text: systemPrompt }] }
    };

    // מנגנון Retry למניעת קריסות
    let retries = 0;
    const maxRetries = 5;

    while (retries <= maxRetries) {
        try {
            const response = await fetch(url, {
                method: 'POST',
                body: JSON.stringify(payload),
                headers: { 'Content-Type': 'application/json' }
            });

            if (response.ok) {
                const result = await response.json();
                return result.candidates?.[0]?.content?.parts?.[0]?.text || "מצטער, לא הצלחתי לייצר תשובה.";
            }

            if (response.status !== 429 && response.status < 500) {
                throw new Error(`API Error: ${response.status}`);
            }
        } catch (err) {
            if (retries === maxRetries) throw err;
        }

        const waitTime = Math.pow(2, retries) * 1000;
        await new Promise(resolve => setTimeout(resolve, waitTime));
        retries++;
    }

    return "מצטער, יש עומס על השרת. נסה שוב בעוד רגע.";
}
